# Copy this file to .env and fill local model/provider values.
# run.sh loads this file and automatically wires these keys as local providers.

CERUL_ASR_MODEL=whisper-1
CERUL_ASR_API_KEY=
CERUL_ASR_BASE_URL=https://api.openai.com/v1

CERUL_EMBEDDING_MODEL=gemini-embedding-2
CERUL_EMBEDDING_API_KEY=
CERUL_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta

CERUL_VIDEO_UNDERSTANDING_MODEL=gemini-3.5-flash
CERUL_VIDEO_UNDERSTANDING_API_KEY=
CERUL_VIDEO_UNDERSTANDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Local vector index. By default Cerul uses http://127.0.0.1:6333 and will
# start a bundled qdrant binary when available.
CERUL_QDRANT_URL=http://127.0.0.1:6333
CERUL_QDRANT_API_KEY=
CERUL_QDRANT_AUTOSTART=1
# CERUL_QDRANT_BIN=/absolute/path/to/qdrant
